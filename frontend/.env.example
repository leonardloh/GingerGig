# ─── GingerGig Frontend — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# Base URL of the GingerGig backend origin only. No trailing slash and no /api/v1.
# The frontend automatically appends /api/v1 before every endpoint path in http.ts.
# Local development:
VITE_API_BASE_URL=http://localhost:8000
# Staging / production (uncomment and set):
# VITE_API_BASE_URL=https://<alibaba-ecs-or-slb-host>

# Request timeout in milliseconds (default: 15000).
# Requests that exceed this are aborted and surface as { status: 408 }.
VITE_API_TIMEOUT_MS=15000
