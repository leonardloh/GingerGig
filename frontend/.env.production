# Production-only overrides — applied automatically by Vite during `npm run build`.
# Do NOT use these values for local dev (keep .env values empty for that).

# CDN base URL — all public images (hero, slides, wordmark) are served from here.
VITE_CDN_URL=https://d3s4i3h2d09lj8.cloudfront.net

# Flip to false ONLY when the real FastAPI backend is deployed and reachable.
# Keep true while previewing locally without a running backend.
VITE_USE_MOCK_API=false
VITE_API_BASE_URL=https://47.250.13.227.sslip.io